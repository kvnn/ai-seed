# Required vendor keys
OPENAI_API_KEY=

# Optional vendor keys
FIRECRAWL_API_KEY=

# Local networking
BACKEND_HOST=0.0.0.0
API_HOST_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:5176,http://localhost:3000
FRONTEND_HOST_PORT=5176

# Local runtime
OUTPUT_DIR=./data
GENERATOR_MODEL=deterministic-seed
DB_ENGINE_URL=sqlite:///./data/oahuai.db
# Optional compose-only override:
# BACKEND_DB_ENGINE_URL=postgresql+psycopg://user:password@host:5432/dbname

# Simple auth bootstrap
APP_PASSWORD=
INVITE_CODE=
JWT_SECRET=change-me-before-sharing
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
BOOTSTRAP_DB=true
